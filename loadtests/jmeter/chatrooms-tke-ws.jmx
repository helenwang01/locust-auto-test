        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="房内发送者发消息">
          <stringProp name="IfController.condition">${__groovy(&quot;true&quot;.equals(vars.get(&quot;is_sender&quot;)))}</stringProp>
