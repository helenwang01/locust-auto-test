        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="收消息">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">import com.easemob.im.call.Call

def appKey = vars.get(&apos;org_name&apos;) + &apos;#&apos; + vars.get(&apos;app_name&apos;)
def url = vars.get(&apos;msync_url&apos;)
def from = vars.get(&apos;username&apos;) ?: (vars.get(&apos;user_prefix&apos;) + ctx.getThreadNum())
long timeout = (vars.get(&apos;timeout_ms&apos;) ?: &apos;10000&apos;) as long

def ret = Call.getInstance(appKey, url).receive(from, timeout)
if (ret == &apos;not user&apos; || ret == &apos;disConnected&apos; || ret == &apos;error&apos;) {
    def password = vars.get(&apos;password&apos;)
    def call = Call.getInstance(appKey, url)
    synchronized (call) {
        call.create(from, password)
        call.login(from, password, timeout)
        ret = call.joinChatRoom(from, vars.get(&apos;room_id&apos;), timeout)
    }
    if (ret != &apos;success&apos; &amp;&amp; ret != &apos;empty&apos;) {
        ret = call.receive(from, timeout)
    }
}
SampleResult.setSuccessful(ret != &apos;error&apos; &amp;&amp; ret != &apos;not user&apos;)
SampleResult.setResponseMessage(String.valueOf(ret))
SampleResult.setDataType(org.apache.jmeter.samplers.SampleResult.TEXT)
SampleResult.setResponseData((&quot;receive user=${from} ret=${ret}&quot;).getBytes(&quot;UTF-8&quot;))
</stringProp>
        </JSR223Sampler>
