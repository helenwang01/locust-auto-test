        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="发聊天室自定义消息">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="script">import com.easemob.im.call.Call
import com.easemob.im.message.model.MessageBody

def appKey = vars.get(&apos;org_name&apos;) + &apos;#&apos; + vars.get(&apos;app_name&apos;)
def url = vars.get(&apos;msync_url&apos;)
def from = vars.get(&apos;username&apos;) ?: (vars.get(&apos;user_prefix&apos;) + ctx.getThreadNum())
def roomId = vars.get(&apos;room_id&apos;)


def content = [text: &apos;ROOM_CHAT&apos;]

def call = Call.getInstance(appKey, url)
def ret
ret = call.sendToChatRoom(from, roomId, content, MessageBody.Content.Type.TEXT, 1L)
if (ret != &apos;success&apos;) {
    log.warn(&quot;send failed from=${from} room=${roomId} ret=${ret}&quot;)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseMessage(ret)
    SampleResult.setDataType(org.apache.jmeter.samplers.SampleResult.TEXT)
    SampleResult.setResponseData((&quot;send failed from=${from} room=${roomId} ret=${ret}&quot;).getBytes(&quot;UTF-8&quot;))
} else {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseMessage(&apos;success&apos;)
    SampleResult.setDataType(org.apache.jmeter.samplers.SampleResult.TEXT)
    SampleResult.setResponseData((&quot;send success from=${from} room=${roomId} seq=${seq}&quot;).getBytes(&quot;UTF-8&quot;))
}
</stringProp>
          </JSR223Sampler>
