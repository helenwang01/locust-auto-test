          <stringProp name="BeanShellSampler.query">package com.easemob.im.call;

import com.easemob.im.message.model.MessageBody;
import org.junit.jupiter.api.Test;

import java.io.IOException;
import java.util.HashMap;
import java.util.Map;

String appKey = &quot;${org_name}#${app_name}&quot;;
String url = &quot;${wsurl}&quot;;
String username = &quot;${prename}${userid}&quot;;
String password = &quot;${password}&quot;;
String s = Call.getWsInstance(appKey, url).create(username, password,false);

String s1 = Call.getWsInstance(appKey, url).login(username, password, ${timeout});
if(!s1.equals(&quot;success&quot;)){
	log.info(&quot;login:&quot;+s1);
	IsSuccess = false;
	ResponseCode = 500;
	for(int i=0;i&lt;3;i++)
	{
		s1 = Call.getWsInstance(appKey, url).login(username, password, ${timeout});
		//log.info(&quot;login:&quot;+username+&quot;:&quot;+password+&quot;:&quot;+s1);
		if(s1.equals(&quot;success&quot;))
		{
			IsSuccess = true;
			ResponseCode = 200;
			break;	
		}
	}
}
</stringProp>
