import java.util.Map;
import com.easemob.im.call.Call;
import com.easemob.im.message.model.MessageBody;
import com.github.javafaker.Faker;
String appKey = &quot;${org_name}#${app_name}&quot;;
String url = &quot;${wsurl}&quot;;
String from = &quot;${prename}${__Random(${__BeanShell(1+${num}*${thread}+(${__threadNum}-1)*${roommembers},)},${__BeanShell(${num}*${thread}+${__threadNum}*${roommembers},)},)}&quot;;
String time = &quot;${__time(,)}&quot;;
String to = &quot;${prename2}-test1-${__BeanShell(${__threadNum}+${num}*${__BeanShell(${thread}/${roommembers},)},)}&quot;;
Faker faker = new Faker(new Locale(&quot;zh-CN&quot;));
String randomSentence = faker.lorem().sentence(${wordcount});
Map content = new HashMap();
content.put(&quot;text&quot;, randomSentence);


String s = Call.getWsInstance(appKey, url).sendToChatRoom(from, to, content, MessageBody.Content.Type.TEXT, ${__Random(1,2,)});
log.debug(from+&quot;sendmsg to &quot;+to+&quot; &quot;+s);
log.debug(&quot;counter:&quot;+time);
