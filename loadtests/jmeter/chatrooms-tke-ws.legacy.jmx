              <stringProp name="script">import java.util.HashMap;
import java.util.Map;
import com.easemob.im.call.Call;
import com.easemob.im.message.model.MessageBody;
import com.alibaba.fastjson.JSON;
import com.alibaba.fastjson.JSONObject;

String appKey = &quot;${org_name}#${app_name}&quot;;
String url = &quot;tcp://${host}:${port1}&quot;;
String from = &quot;${prename}${__threadNum}&quot;;


String s2 = Call.getInstance(appKey, url).receive(from, ${timeout});

log.info(from + &quot;receivemsg:&quot; + s2);
vars.put(&quot;messagedelay&quot;,&quot;-1000&quot;);	
if(!s2.equals(&quot;empty&quot;) &amp;&amp; (!s2.equals(&quot;error&quot;) &amp;&amp; !s2.equals(&quot;not user&quot;))){
	vars.put(&quot;messagedelay&quot;,s2);
}
else if(s2.equals(&quot;error&quot;)){
	vars.put(&quot;msgerror&quot;,&quot;400&quot;);
}
else if(s2.equals(&quot;not user&quot;)){
	vars.put(&quot;msgerror&quot;,&quot;500&quot;);
}
//if(!s2.equals(&quot;success&quot;)) {
//	IsSuccess = false;
//}</stringProp>
