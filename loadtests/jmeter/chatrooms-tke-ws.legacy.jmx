            <stringProp name="BeanShellSampler.query">import java.util.HashMap;
import java.util.Map;
import com.easemob.im.call.Call;
import com.easemob.im.message.model.MessageBody;

String appKey = &quot;${org_name}#${app_name}&quot;;
String url = &quot;tcp://${host}:${port1}&quot;;
String from = &quot;${prename}${__threadNum}&quot;;
String time = &quot;${__time(,)},${__counter(FALSE,)}&quot;;
String to = &quot;${roomid}&quot;;

Map content = new HashMap();
content.put(&quot;text&quot;, &quot;testText&quot;+time);

String s = Call.getInstance(appKey, url).sendToChatRoom(from, to, content, MessageBody.Content.Type.TEXT, ${__Random(1,2,)});
log.info(from+&quot;sendmsg to &quot;+to+&quot; &quot;+s);
log.info(&quot;counter:&quot;+time);

if(!s.equals(&quot;success&quot;)) {
	IsSuccess = false;
}

</stringProp>
